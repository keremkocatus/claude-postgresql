# ── Connection (required) ──────────────────────────────────────────────
PG_MCP_DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── Pool ──────────────────────────────────────────────────────────────
# PG_MCP_POOL_MIN_SIZE=2
# PG_MCP_POOL_MAX_SIZE=10
# PG_MCP_COMMAND_TIMEOUT=30
# PG_MCP_STATEMENT_TIMEOUT=30000

# ── Safety & Limits ──────────────────────────────────────────────────
# PG_MCP_READ_ONLY=false
# PG_MCP_MAX_RESULT_ROWS=500
# PG_MCP_MAX_QUERY_LENGTH=10000

# ── Whitelists (JSON arrays, empty = allow all) ─────────────────────
# PG_MCP_ALLOWED_SCHEMAS=["public"]
# PG_MCP_ALLOWED_TABLES=["public.users", "public.orders"]

# ── Query History Persistence ────────────────────────────────────────
# Set BOTH to enable. Leave as-is (commented) to disable.
# PG_MCP_QUERY_HISTORY_TABLE=public.mcp_query_history
# PG_MCP_QUERY_HISTORY_DB=postgresql://user:password@localhost:5432/history_db

# ── SSL / TLS (optional) ────────────────────────────────────────────
# PG_MCP_SSL_ENABLED=false
# PG_MCP_SSL_CA_FILE=/path/to/ca.pem
# PG_MCP_SSL_CERT_FILE=/path/to/client-cert.pem
# PG_MCP_SSL_KEY_FILE=/path/to/client-key.pem
# PG_MCP_SSL_REQUIRE=true

# ── Logging ──────────────────────────────────────────────────────────
# PG_MCP_LOG_QUERIES=true
# PG_MCP_LOG_LEVEL=INFO

# ── Transport / Deployment ───────────────────────────────────────────
# PG_MCP_TRANSPORT=stdio          # "stdio" (local) | "sse" | "streamable-http" (Railway)
# PG_MCP_HOST=0.0.0.0
# PG_MCP_PORT=8000                # Railway injects PORT automatically

# ── Authentication (REQUIRED for sse/streamable-http deployments) ──────
# Without these, anyone who has your deployment's URL has full database access.
# Generate a token with: python -c "import secrets; print(secrets.token_urlsafe(24))"
# PG_MCP_ADMIN_PASSWORD=
# PG_MCP_PUBLIC_URL=https://your-app.up.railway.app
